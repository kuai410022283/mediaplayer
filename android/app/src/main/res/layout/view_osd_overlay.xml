<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/layoutOsd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_osd_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/size_48"
        android:paddingBottom="@dimen/size_32"
        android:paddingTop="@dimen/size_64"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <TextView
                android:id="@+id/tvOsdChannelNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="001"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_48"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvOsdChannelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_48"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                app:layout_constrainedWidth="true"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvOsdChannelNum"
                app:layout_constraintEnd_toStartOf="@id/tvOsdLineInfo"
                tools:text="CCTV-1 综合" />

            <TextView
                android:id="@+id/tvOsdLineInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="@dimen/text_24"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginEnd="@dimen/dp_16"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvOsdChannelName"
                app:layout_constraintEnd_toStartOf="@id/tvOsdInfo"
                app:layout_constraintHorizontal_bias="0"
                tools:text="1/6" />

            <!-- 右侧网速、时间、编码等 -->
            <TextView
                android:id="@+id/tvOsdInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="@dimen/text_22"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="1080P | H264 | AC3" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_8">
            
            <TextView
                android:id="@+id/tvOsdEpg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#DDDDDD"
                android:textSize="@dimen/text_24"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvOsdNextEpg"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="80dp"
                app:layout_goneMarginEnd="80dp"
                tools:text="正在播放: 精彩节目" />
                
            <TextView
                android:id="@+id/tvOsdNextEpg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="@dimen/text_24"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                app:layout_constrainedWidth="true"
                app:layout_constraintWidth_max="400dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="接下来: 精彩节目" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- VOD 控制行：左侧播放状态+当前时间，右侧总时长（直播模式下隐藏） -->
        <LinearLayout
            android:id="@+id/layoutVodControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/dp_8"
            android:visibility="gone">

            <!-- 固定宽度图标区域（防止图标变化导致时间晃动） -->
            <ImageView
                android:id="@+id/tvVodIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_vod_play"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvVodCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_8"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_24"
                android:text="00:00:00" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvVodTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="@dimen/text_24"
                android:text="00:00:00"
                android:nextFocusRight="@+id/tvBtnAudio" />

            <TextView
                android:id="@+id/tvBtnAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_24"
                android:focusable="true"
                android:clickable="true"
                android:nextFocusLeft="@id/tvBtnAudio"
                android:paddingHorizontal="@dimen/dp_16"
                android:paddingVertical="@dimen/dp_4"
                android:visibility="gone"
                android:text="音轨" />

            <TextView
                android:id="@+id/tvBtnSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_24"
                android:focusable="true"
                android:clickable="true"
                android:nextFocusRight="@id/tvBtnSubtitle"
                android:paddingHorizontal="@dimen/dp_16"
                android:paddingVertical="@dimen/dp_4"
                android:visibility="gone"
                android:text="字幕" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressEpg"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_4"
            android:layout_marginTop="@dimen/dp_12"
            android:progress="30"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="#44FFFFFF"/>

        <!-- VOD SeekBar：可拖动进度条（直播模式下隐藏） -->
        <SeekBar
            android:id="@+id/seekBarVod"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_4"
            android:max="1000"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            android:progressBackgroundTint="#44FFFFFF"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:visibility="gone" />
    </LinearLayout>

</merge>
